# DriftWatch — local environment template.
# Copy to .env and fill in real values: `cp .env.example .env`
# .env is gitignored. NEVER commit secrets.
# See docs - DO NOT COMMIT/.planning/phases/00-skeleton-compose/00-CONTEXT.md (D-16).

# --- Postgres (shared single container, three logical DBs) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
PLATFORM_DATABASE_URL=postgresql+psycopg://postgres:change-me@postgres:5432/platform
AGENT_DATABASE_URL=postgresql+psycopg://postgres:change-me@postgres:5432/agent
MLFLOW_BACKEND_URI=postgresql+psycopg2://postgres:change-me@postgres:5432/mlflow

# --- Redis (LangGraph checkpointer + arq queue) ---
REDIS_URL=redis://redis:6379/0

# --- MLflow ---
MLFLOW_TRACKING_URI=http://mlflow:5000
MLFLOW_ARTIFACT_ROOT=/mlflow/artifacts

# --- Service-to-service auth (D-08 in DECISIONS.md) ---
# 32+ random bytes; generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
WEBHOOK_HMAC_SECRET=change-me-32-bytes-min
PROMOTION_BEARER_TOKEN=change-me

# --- LLM (Groq llama-3.3-70b-versatile per locked stack) ---
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# --- LangSmith tracing (optional, env-gated) ---
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=

# --- Service URLs (used for service-to-service calls inside the compose network) ---
PLATFORM_URL=http://platform:8000
AGENT_URL=http://agent:8000

# --- Service runtime ---
APP_ENV=local
LOG_LEVEL=INFO
