# DriftWatch — local environment template.
# Copy to .env and fill in real values: `cp .env.example .env`
# .env is gitignored. NEVER commit secrets.
# See docs - DO NOT COMMIT/.planning/phases/00-skeleton-compose/00-CONTEXT.md (D-16).

# --- Postgres (shared single container, three logical DBs) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
PLATFORM_DATABASE_URL=postgresql+psycopg://postgres:change-me@postgres:5432/platform
AGENT_DATABASE_URL=postgresql+psycopg://postgres:change-me@postgres:5432/agent
MLFLOW_BACKEND_URI=postgresql+psycopg2://postgres:change-me@postgres:5432/mlflow

# --- Redis (LangGraph checkpointer + arq queue) ---
REDIS_URL=redis://redis:6379/0

# --- MLflow ---
MLFLOW_TRACKING_URI=http://mlflow:5000
MLFLOW_ARTIFACT_ROOT=/mlflow/artifacts
MLFLOW_EXPERIMENT_NAME=DriftWatch Bank Marketing
MLFLOW_REGISTERED_MODEL_NAME=driftwatch-bank-marketing
MLFLOW_HTTP_REQUEST_TIMEOUT=5
MLFLOW_HTTP_REQUEST_MAX_RETRIES=1
MLFLOW_HTTP_REQUEST_BACKOFF_FACTOR=0

# --- ML pipeline ---
DATA_PATH=platform/data/bank-additional-full.csv
ARTIFACT_DIR=platform/artifacts
RANDOM_STATE=42
SPLIT_TRAIN_SIZE=0.60
SPLIT_VALIDATION_SIZE=0.20
SPLIT_TEST_SIZE=0.20
MIN_RECALL=0.75
MODEL_VERSION_LABEL=v1
REPLAY_CSV_PATH=/app/data/bank-additional-full.csv
RETRAIN_CSV_PATH=/app/data/bank-additional-full.csv

# --- Service-to-service auth (D-08 in DECISIONS.md) ---
# 32+ random bytes; generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
WEBHOOK_HMAC_SECRET=change-me-32-bytes-min
PROMOTION_BEARER_TOKEN=change-me
WEBHOOK_TIMEOUT_SECONDS=5
AGENT_WEBHOOK_URL=http://agent:8000/webhooks/drift

# --- LLM (Groq llama-3.3-70b-versatile per locked stack) ---
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# --- LangSmith tracing (optional, env-gated) ---
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=

# --- Service URLs (used for service-to-service calls inside the compose network) ---
PLATFORM_URL=http://platform:8000
AGENT_URL=http://agent:8000
DASHBOARD_DATA_PATH=/app/data/bank-additional-full.csv

# --- Service runtime ---
APP_ENV=local
LOG_LEVEL=INFO

# --- Platform model serving ---
MLFLOW_MODEL_ALIAS=Production
MODEL_ARTIFACT_DIR=platform/artifacts/model_v1
DEFAULT_MODEL_PATH=platform/artifacts/model_v1/model.pkl
DEFAULT_THRESHOLD_PATH=platform/artifacts/model_v1/threshold.json
DEFAULT_SCHEMA_PATH=platform/artifacts/model_v1/schema.json

# --- Platform drift monitoring ---
DRIFT_WINDOW_SIZE=200
DRIFT_MIN_WINDOW_SIZE=50
PSI_LOW_THRESHOLD=0.10
PSI_MEDIUM_THRESHOLD=0.20
PSI_HIGH_THRESHOLD=0.30
CHI2_PVALUE_THRESHOLD=0.05
OUTPUT_DRIFT_PSI_THRESHOLD=0.20
